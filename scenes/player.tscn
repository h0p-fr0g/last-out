[sub_resource type="GDScript" id="GDScript_g2els"]
script/source = "extends CharacterBody2D

@export var speed: float = 160.0

# Referenz auf die Bullet-Szene.
@export var bullet_scene: PackedScene

@onready var anim: AnimatedSprite2D = $AnimatedSprite2D
@onready var footsteps: AudioStreamPlayer2D = $Footsteps
@onready var muzzle: Marker2D = $Muzzle

# Speichert die aktuelle Blickrichtung für Animationen.
var last_direction: String = \"down\"

func _ready() -> void:
	anim.frame_changed.connect(_on_anim_frame_changed)

func _physics_process(_delta: float) -> void:
	# Bewegung per WASD.
	var input_dir := Input.get_vector(\"move_left\", \"move_right\", \"move_up\", \"move_down\")
	velocity = input_dir * speed
	move_and_slide()

	# Blickrichtung per Maus aktualisieren.
	update_look_direction()

	# Animation aktualisieren.
	update_animation(input_dir)

	# Schuss bei Tastendruck.
	if Input.is_action_just_pressed(\"shoot\"):
		shoot()

func update_look_direction() -> void:
	# Richtungsvektor vom Spieler zur Maus.
	var mouse_dir := get_global_mouse_position() - global_position

	# Falls Maus exakt auf dem Spieler liegt, nichts ändern.
	if mouse_dir.length() == 0:
		return

	# Vier Richtungen anhand der stärkeren Achse bestimmen.
	if abs(mouse_dir.x) > abs(mouse_dir.y):
		if mouse_dir.x > 0:
			last_direction = \"right\"
		else:
			last_direction = \"left\"
	else:
		if mouse_dir.y > 0:
			last_direction = \"down\"
		else:
			last_direction = \"up\"

func update_animation(input_dir: Vector2) -> void:
	if input_dir != Vector2.ZERO:
		anim.play(\"walk_\" + last_direction)

		if not footsteps.playing:
			footsteps.play()
	else:
		anim.play(\"idle_\" + last_direction)
		footsteps.stop()

func shoot() -> void:
	# Prüfen, ob überhaupt eine Bullet-Szene zugewiesen wurde.
	if bullet_scene == null:
		return

	# Mausposition im Weltkoordinatensystem holen.
	var mouse_pos := get_global_mouse_position()

	# Richtung vom Spieler zur Maus berechnen und normalisieren.
	var shoot_dir := (mouse_pos - global_position).normalized()

	# Falls aus irgendeinem Grund keine gültige Richtung entsteht, abbrechen.
	if shoot_dir == Vector2.ZERO:
		return

	# Bullet erzeugen.
	var bullet = bullet_scene.instantiate()

	# Startposition:
	# entweder vom Muzzle-Marker,
	# oder alternativ leicht vor dem Spieler.
	bullet.global_position = muzzle.global_position

	# Flugrichtung an die Bullet übergeben.
	bullet.direction = shoot_dir

	# Bullet der Hauptszene hinzufügen.
	# So bleibt sie nicht am Spieler \"hängen\".
	get_tree().current_scene.add_child(bullet)

func _on_anim_frame_changed() -> void:
	# Optional für Schrittgeräusche auf bestimmten Frames.
	if anim.animation.begins_with(\"walk_\"):
		if anim.frame == 0 or anim.frame == 2:
			if not footsteps.playing:
				footsteps.play()
"

