[sub_resource type="GDScript" id="GDScript_rtl8c"]
resource_name = "Bullet"
script/source = "extends Area2D

# Geschwindigkeit der Kugel in Pixel pro Sekunde.
@export var speed: float = 500.0

# Lebensdauer der Kugel in Sekunden.
@export var lifetime: float = 2.0

# Bewegungsrichtung der Kugel.
# Diese wird direkt nach dem Erzeugen vom Spieler gesetzt.
var direction: Vector2 = Vector2.ZERO

func _ready() -> void:
	# Kugel in Flugrichtung drehen, damit Sprite optisch korrekt ausgerichtet ist.
	rotation = direction.angle()

	# Nach einer festen Zeit automatisch löschen,
	# damit alte Kugeln nicht ewig in der Szene bleiben.
	await get_tree().create_timer(lifetime).timeout
	queue_free()

func _physics_process(delta: float) -> void:
	# Bewegt die Kugel jedes Physik-Frame entlang ihrer Richtung.
	global_position += direction * speed * delta

func _on_body_entered(body: Node) -> void:
	# Wird ausgelöst, wenn die Kugel einen PhysicsBody berührt,
	# z. B. Wand, TileMap oder Gegner mit passender Kollision.
	
	# Optional: Falls der getroffene Körper eine Trefferfunktion hat,
	# kann man hier Schaden auslösen.
	if body.has_method(\"take_damage\"):
		body.take_damage(1)

	# Kugel nach Treffer entfernen.
	queue_free()

func _on_area_entered(area: Area2D) -> void:
	# Alternative Reaktion, falls du mit Area2D-Gegnern arbeitest.
	if area.has_method(\"take_damage\"):
		area.take_damage(1)

	queue_free()
"

